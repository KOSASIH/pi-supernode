# ========================================
# Network & Stellar Configuration
# ========================================
# Stellar Horizon (Production/Testnet)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# STELLAR_HORIZON_URL=https://horizon.stellar.org  # Mainnet

# Pi Coin Configuration
PI_COIN_ASSET_CODE=PINATIVE
PI_COIN_ISSUER=GPIFOUNDATIONRESERVE
PI_COIN_DISPLAY_SYMBOL=π
PI_NETWORK_PASSPHRASE="Pi Network Testnet"  # or "Pi Network"

# ========================================
# Smart Contracts (Mainnet/Testnet)
# ========================================
TOKEN_CONTRACT_ADDRESS=CBJHGVC3LP7J7FAK5ER5R7EJURZ43RHEKL3PEK7GVOFZZQRSX5MAVJ4W  # Testnet example
SUPPLY_MANAGER_ADDRESS=GC5H5MG3VYK5YU3EN5R3W4ZJ3T5J3J3J3J3J3J3J3J3J3J3J3J3J3J3J  # Update with real
PRICE_FEED_ADDRESS=GCZ5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ  # Oracle

# ========================================
# Node Configuration
# ========================================
NODE_ID=pi-supernode-01
NODE_NAME="Pi Supernode Alpha"
P2P_PORT=30001
API_PORT=8080
LEGACY_RPC_PORT=31401
BIND_ADDRESS=0.0.0.0

# ========================================
# Database & Cache
# ========================================
DATABASE_URL=postgresql://pi:${POSTGRES_PASSWORD}@db:5432/pi_supernode?sslmode=disable
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0?db=0
POSTGRES_PASSWORD=your-super-secure-db-password-change-me!
REDIS_PASSWORD=your-super-secure-redis-password-change-me!

# ========================================
# Security & Wallets (🚨 HIGHLY SENSITIVE)
# ========================================
# Generate with: openssl rand -hex 32
NODE_PRIVATE_KEY=your_64_byte_hex_private_key_here_dont_share
SIGNER_1=GBYOURSIGNER1PUBLICKEYHEREAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
SIGNER_2=GBYOURSIGNER2PUBLICKEYHEREAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
SIGNER_THRESHOLD=2

# Wallet (use hardware wallet in production)
PI_WALLET_ADDRESS=GPIWALLETADDRESSHEREAAAAAAAAAAAAAAAAAAAAAAAAAA
PI_WALLET_SECRET=SYOURWALLETSECRETKEYHEREAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ========================================
# API & CORS
# ========================================
PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://pi-mainnet.org,https://testnet.pi.network
ALLOWED_HOSTS=localhost,127.0.0.1,pi-supernode.local,*.pi.network

# Rate limiting
API_RATE_LIMIT=100  # requests per minute
RPC_RATE_LIMIT=50

# ========================================
# Logging & Monitoring
# ========================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json, text
REQUEST_LOGGING=true

# ========================================
# Cloud & External Services
# ========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}

# Optional: Cloud provider endpoints
CLOUD_STORAGE_ENDPOINT=s3.amazonaws.com
METRICS_ENDPOINT=http://prometheus:9090

# ========================================
# P2P Network
# ========================================
BOOTSTRAP_NODES=/ip4/44.232.55.71/tcp/30001/p2p/12D3KooWCwevHg1yLCvktf2nvH56hKX3nkeW3pH8r5uJ6q9k9L9m,/ip4/44.232.55.72/tcp/30001/p2p/12D3KooWCwevHg2yLCvktf2nvH56hKX3nkeW3pH8r5uJ6q9k9L9n
MAX_PEERS=50
P2P_ANNOUNCE=false

# ========================================
# Feature Flags
# ========================================
ENABLE_EXPLORER=true
ENABLE_RPC=true
ENABLE_P2P=true
REQUIRE_AUTH=false  # Set to true in production
MAINTENANCE_MODE=false

# ========================================
# Performance
# ========================================
MAX_REQUEST_BODY=1048576  # 1MB
WORKER_THREADS=4
MAX_CONCURRENT_REQUESTS=100

# ========================================
# Health & Monitoring
# ========================================
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true
TRACING_ENABLED=false

# ========================================
# Pi Network Specific
# ========================================
PI_CHAIN_ID=pi-testnet-01
PI_VERSION=2.0.0
MIN_PI_BURN=1000000  # Minimum burn for transactions
