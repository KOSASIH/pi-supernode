HTTP_PORT=8080
GRPC_PORT=9090
PROMETHEUS_PORT=9091
HEALTH_PORT=8081
LEGACY_RPC_PORT=31401
GRAFANA_PORT=3000

# ========================================
# 🔐 SECURITY & CRYPTO (GENERATED - KEEP SECRET!)
# ========================================
