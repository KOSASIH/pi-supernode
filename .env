# ========================================
# Core Node Configuration
# ========================================
NODE_ID=pi-supernode-01
NODE_NAME="Pi Supernode Alpha v2.0"
BUILD_VERSION=2.0.0
PI_CHAIN_ID=pi-testnet-01

# Ports (All services)
P2P_PORT=30001
HTTP_PORT=8080
GRPC_PORT=9090
PROMETHEUS_PORT=9091
HEALTH_PORT=8081
LEGACY_RPC_PORT=31401

# ========================================
# Security & Crypto (🚨 CRITICAL - CHANGE THESE!)
# ========================================
# Generate: openssl rand -hex 32
NODE_PRIVATE_KEY=your_64_byte_hex_private_key_here_32_bytes_exactly
PI_WALLET_SECRET=SYOUR32CHARACTERSECRETKEYHEREAAAAAAAAAAAAAAAAAAAAAAA

# Stellar Signers (Public keys only)
SIGNER_1=GBYOURPUBLICSIGNER1KEYHEREAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
SIGNER_2=GBYOURPUBLICSIGNER2KEYHEREAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
SIGNER_THRESHOLD=2

# Wallet Address (Public)
PI_WALLET_ADDRESS=GPIWALLETADDRESSHEREAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ========================================
# Database & Cache (Production Ready)
# ========================================
POSTGRES_PASSWORD=PiSupernode2024!x7K9mP2vQ8wL5nR3tY6uJ1zB4cF0hE2gA
REDIS_PASSWORD=RedisPiNode2024!kM8nQ3vW5xL9pR7tY2uJ6zB1cF4hE0gD

DATABASE_URL=postgresql://pi:${POSTGRES_PASSWORD}@db:5432/pi_supernode?sslmode=disable&connect_timeout=10
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0?db=0

# ========================================
# Stellar & Pi Network
# ========================================
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# STELLAR_HORIZON_URL=https://horizon.stellar.org  # Mainnet ⚠️

PI_COIN_ASSET_CODE=PINATIVE
PI_COIN_ISSUER=GPIFOUNDATIONRESERVE
PI_COIN_DISPLAY_SYMBOL=π
PI_NETWORK_PASSPHRASE="Pi Network Testnet"

# Smart Contracts
TOKEN_CONTRACT_ADDRESS=CBJHGVC3LP7J7FAK5ER5R7EJURZ43RHEKL3PEK7GVOFZZQRSX5MAVJ4W
SUPPLY_MANAGER_ADDRESS=GC5H5MG3VYK5YU3EN5R3W4ZJ3T5J3J3J3J3J3J3J3J3J3J3J3J3J3J3J
PRICE_FEED_ADDRESS=GCZ5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ

# ========================================
# Observability (OpenTelemetry + Prometheus)
# ========================================
OTLP_ENDPOINT=localhost:4317
METRICS_ENABLED=true
TRACING_ENABLED=true
REQUEST_LOGGING=true
LOG_LEVEL=info
LOG_FORMAT=json

PROMETHEUS_PORT=9091
OTEL_SERVICE_NAME=pi-supernode
OTEL_RESOURCE_ATTRIBUTES=service.version=2.0.0,deployment.environment=production

# ========================================
# API & Security
# ========================================
BIND_ADDRESS=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://pi-mainnet.org,https://testnet.pi.network,https://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,pi-supernode.local,*.pi.network,*.ngrok.io

# Rate Limiting (req/min)
API_RATE_LIMIT=1000
RPC_RATE_LIMIT=500
P2P_RATE_LIMIT=100

MAX_REQUEST_BODY=10485760  # 10MB
MAX_CONCURRENT_REQUESTS=200

# ========================================
# P2P Network (libp2p QUIC)
# ========================================
BOOTSTRAP_NODES=/ip4/44.232.55.71/udp/30001/quic-v1/p2p/12D3KooWCwevHg1yLCvktf2nvH56hKX3nkeW3pH8r5uJ6q9k9L9m,/ip4/44.232.55.72/udp/30001/quic-v1/p2p/12D3KooWCwevHg2yLCvktf2nvH56hKX3nkeW3pH8r5uJ6q9k9L9n
MAX_PEERS=250
P2P_ANNOUNCE=true
P2P_PROTOCOL=/pi/2.0.0

# ========================================
# Performance & Resources
# ========================================
WORKER_THREADS=8
TPS_TARGET=1000
MIN_PI_BURN=1000000

# ========================================
# Feature Flags
# ========================================
ENABLE_EXPLORER=true
ENABLE_RPC=true
ENABLE_P2P=true
ENABLE_GRPC=true
REQUIRE_AUTH=false
MAINTENANCE_MODE=false
QUIC_ONLY=false

# ========================================
# Cloud & External Services
# ========================================
AWS_REGION=us-east-1
AWS_BUCKET=pi-supernode-data
CLOUD_STORAGE_ENDPOINT=s3.amazonaws.com

# Optional: External services
METRICS_ENDPOINT=http://prometheus:9090
GRAFANA_ENDPOINT=http://grafana:3000

# ========================================
# Health & Monitoring
# ========================================
HEALTH_CHECK_INTERVAL=10
SHUTDOWN_TIMEOUT=15

# ========================================
# Pi Network Advanced
# ========================================
PI_VERSION=2.0.0
ENABLE_ZK_PROOF=true
ZK_CIRCUIT_PATH=/data/zk-circuit.json
