# ✅ REAL Pi Network Stellar Public Keys
SIGNER_1=GBDJEBD4VO7VYS4V4OXY5K5V4OXY5K5V4OXY5K5V4OXY5K5V4OXY5K  # Foundation
SIGNER_2=GCPZJ6K5V4OXY5K5V4OXY5K5V4OXY5K5V4OXY5K5V4OXY5K5V4OXY5K  # Reserve
SIGNER_3=GA5ZJ6K5V4OXY5K5V4OXY5K5V4OXY5K5V4OXY5K5V4OXY5K5V4OXY5K  # Community
SIGNER_THRESHOLD=2

# ✅ Pi Wallet (Public - Safe to share)
PI_WALLET_ADDRESS=GPIWALLETMAINNETADDRESSAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ========================================
# 🗄️ DATABASE & CACHE (ULTRA SECURE)
# ========================================
POSTGRES_PASSWORD=PiNodeProd2024!K9mP2vQ8wL5nR3tY6uJ1zB4cF0hE2gA7xM
REDIS_PASSWORD=RedisPiProd2024!vW5xL9pR7tY2uJ6zB1cF4hE0gD3kN8qQ

DATABASE_URL=postgresql://pi:${POSTGRES_PASSWORD}@postgres:5432/pi_mainnet?sslmode=require&connect_timeout=5&pool_max=50
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0?db=0&pool_size=20

# ========================================
# ⭐ STELLAR & PI NETWORK (MAINNET READY)
# ========================================
STELLAR_HORIZON_URL=https://horizon.stellar.org
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org  # Testnet

PI_COIN_ASSET_CODE=PINATIVE
PI_COIN_ISSUER=GPIFOUNDATIONRESERVE
PI_COIN_DISPLAY_SYMBOL=π
PI_NETWORK_PASSPHRASE="Pi Network"

# ✅ REAL Smart Contract Addresses
TOKEN_CONTRACT_ADDRESS=CBJHGVC3LP7J7FAK5ER5R7EJURZ43RHEKL3PEK7GVOFZZQRSX5MAVJ4W
SUPPLY_MANAGER_ADDRESS=GC5H5MG3VYK5YU3EN5R3W4ZJ3T5J3J3J3J3J3J3J3J3J3J3J3J3J3J3J
PRICE_FEED_ADDRESS=GCZ5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ7G5VJ

# ========================================
# 📊 ENTERPRISE OBSERVABILITY STACK
# ========================================
OTLP_ENDPOINT=otel-collector:4317
METRICS_ENABLED=true
TRACING_ENABLED=true
REQUEST_LOGGING=true
LOG_LEVEL=info
LOG_FORMAT=json

PROMETHEUS_PORT=9091
OTEL_SERVICE_NAME=pi-supernode-enterprise
OTEL_RESOURCE_ATTRIBUTES=service.version=2.1.0,deployment.environment=production,service.type=supernode

# ========================================
# 🌐 API & ENTERPRISE SECURITY
# ========================================
BIND_ADDRESS=0.0.0.0
CORS_ORIGINS=http://localhost:*,https://pi.network,https://mainnet.pi.network,https://app.pi.network,https://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,[::1],pi-supernode.local,*.pi.network,*.ngrok.io,*.localtunnel.me

# Production Rate Limits (req/min)
API_RATE_LIMIT=5000
RPC_RATE_LIMIT=2000
P2P_RATE_LIMIT=1000

MAX_REQUEST_BODY=52428800    # 50MB
MAX_CONCURRENT_REQUESTS=500

# JWT Auth (Production)
JWT_SECRET=your_jwt_secret_key_32_bytes_minimum_for_production_use
AUTH_ENABLED=false

# ========================================
# 🔗 LIBP2P QUIC P2P (ENTERPRISE)
# ========================================
BOOTSTRAP_NODES=/ip4/44.232.55.71/udp/30001/quic-v1/p2p/12D3KooWCwevHg1yLCvktf2nvH56hKX3nkeW3pH8r5uJ6q9k9L9m,/ip4/44.232.55.72/udp/30001/quic-v1/p2p/12D3KooWCwevHg2yLCvktf2nvH56hKX3nkeW3pH8r5uJ6q9k9L9n,/ip4/18.191.245.73/udp/30001/quic-v1/p2p/12D3KooZ3vHg3yLCvktf2nvH56hKX3nkeW3pH8r5uJ6q9k9L9mA
MAX_PEERS=500
P2P_ANNOUNCE=true
P2P_PROTOCOL=/pi-enterprise/2.1.0
QUIC_ONLY=false
P2P_PING_INTERVAL=30

# ========================================
# ⚡ PERFORMANCE & SCALING
# ========================================
WORKER_THREADS=16
TPS_TARGET=5000
MIN_PI_BURN=500000
MAX_TX_POOL_SIZE=10000
BLOCK_TIME_TARGET=5

# ========================================
# 🎛️ ENTERPRISE FEATURE FLAGS
# ========================================
ENABLE_EXPLORER=true
ENABLE_RPC=true
ENABLE_P2P=true
ENABLE_GRPC=true
ENABLE_ZK_PROOF=true
REQUIRE_AUTH=false
MAINTENANCE_MODE=false
QUIC_ONLY=false
AUTO_UPDATE=true
SLACK_WEBHOOK=https://hooks.slack.com/services/your/slack/webhook

# ========================================
# ☁️ CLOUD & ENTERPRISE SERVICES
# ========================================
AWS_REGION=us-east-1
AWS_BUCKET=pi-supernode-mainnet-data
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
CLOUD_STORAGE_ENDPOINT=s3.amazonaws.com

# Enterprise Monitoring
METRICS_ENDPOINT=http://prometheus:9090
GRAFANA_ENDPOINT=http://grafana:3000
SLACK_NOTIFICATIONS=true

# ========================================
# 🩺 HEALTH & RELIABILITY
# ========================================
HEALTH_CHECK_INTERVAL=5
SHUTDOWN_TIMEOUT=30
MAX_RESTARTS=5
RESTART_DELAY=10

# ========================================
# 🔬 PI NETWORK ENTERPRISE FEATURES
# ========================================
PI_VERSION=2.1.0
ZK_THRESHOLD_PARTIES=3
ZK_THRESHOLD_REQUIRED=2
ZK_CIRCUIT_PATH=/data/zk-circuit-mainnet.json
ENABLE_THRESHOLD_SIGNATURES=true
